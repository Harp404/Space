# ── Secrets / environment (NEVER commit real keys) ──
.env
.env.*
!.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example
claude.txt

# ── Node / Vue frontend ──
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
.vite/
*.local

# ── Go backend ──
bin/
astromesh
/astromesh
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# ── Local TLE snapshot (we fetch live from CelesTrak; not bundled) ──
frontend/public/tle/

# ── Server-side catalogue cache (fetched from Space-Track, refreshed daily) ──
dev/cache/

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS / editor cruft ──
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Temp ──
tmp/
*.tmp

# Stray model downloads in repo root (real models live in frontend/public/models)
/*.glb
/*.gltf

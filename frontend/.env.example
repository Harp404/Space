# Copy this file to `.env` and fill in your own keys.

# Cesium Ion access token — https://ion.cesium.com/tokens
VITE_CESIUM_TOKEN=your_cesium_ion_token_here

# Google Maps API key (optional, legacy)
VITE_GMAPS_KEY=your_google_maps_key_here

# OpenWeatherMap API key (optional — live cloud layer) https://openweathermap.org/api
VITE_OWM_KEY=your_openweathermap_key_here
